<!-- Justin Gabriel Kristianto - 2572011 -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Game - 2572011</title> 
    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: sans-serif;
        }
        body {
            overflow: hidden;
        }

        #navbar {
            display: flex;
            justify-content: space-around;
            padding: 15px;
            background: black; 
            color: white;
            font-weight: bold;
        }

        #game-area {
            position: relative; 
            width: 100vw;
            height: 100vh;
            background-color: white; 
        }

        #overlay {
            display: flex;
            position: absolute;
            top: 0;   
            left: 0; 
            width: 100%; 
            height: 100%;
            background: white;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 10;
        }

        .target {
            position: absolute;
            transform: translate(-50%, -50%); 
            user-select: none; 
        }

        .hidden {
            display: none !important;
        }

        #game-over-text {
            color: white;
            font-size: 32px;
            margin-bottom: 20px;
            text-align: center;
        }

        #start-btn, #restart-btn {
            background-color: green;
            color: white;
            border: none;
            padding: 10px 30px;
            font-size: 18px;
            border-radius: 8px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div id="navbar">
        <div>Waktu: <span id="time-left">30</span>s</div> 
        <div>Skor: <span id="score">0</span></div> 
    </div>

    <div id="game-area">
        <div id="overlay">
            <div id="game-over-text" class="hidden"></div> 
            <button id="start-btn">Mulai</button> 
            <button id="restart-btn" class="hidden">Restart</button> 
        </div>
    </div>

    <script>
        let score = 0;
        let timeLeft = 30;
        let gameTimer;
        let spawnTimer;

        const scoreDisplay = document.getElementById('score');
        const timeDisplay = document.getElementById('time-left');
        const startBtn = document.getElementById('start-btn');
        const restartBtn = document.getElementById('restart-btn');
        const overlay = document.getElementById('overlay');
        const gameArea = document.getElementById('game-area');
        const gameOverText = document.getElementById('game-over-text');

        const targetTypes = [
            { points: 10, size: 120 },
            { points: 20, size: 100 },
            { points: 50, size: 80 }
        ];

        startBtn.addEventListener('click', () => {
            score = 0;
            timeLeft = 30;
            scoreDisplay.innerText = score;
            timeDisplay.innerText = timeLeft;
            
            overlay.classList.add('hidden');
            
            gameTimer = setInterval(() => {
                timeLeft--;
                timeDisplay.innerText = timeLeft;
                if (timeLeft <= 0) endGame();
            }, 1000);

            spawnTimer = setInterval(createTarget, 500);
        });

        function createTarget() {
            const target = document.createElement('img');
            const type = targetTypes[Math.floor(Math.random() * targetTypes.length)];
            
            target.src = "mole.png";
            target.className = 'target';
            target.style.width = type.size + 'px';
            target.style.height = type.size + 'px';

            const x = Math.random() * (gameArea.clientWidth - type.size) + (type.size / 2);
            const y = Math.random() * (gameArea.clientHeight - type.size) + (type.size / 2);
            
            target.style.left = x + 'px';
            target.style.top = y + 'px';

            target.onclick = () => {
                score = score + type.points;
                scoreDisplay.innerText = score;
                target.remove();
            };

            gameArea.appendChild(target);

            setTimeout(() => {
                if (target.parentNode) {
                    target.remove();
                }
            }, 1500);
        }

        function endGame() {
            clearInterval(gameTimer);
            clearInterval(spawnTimer);
            
            document.querySelectorAll('.target').forEach(t => t.remove());

            gameOverText.innerText = "Game Over!\nSkor Akhir: " + score;
            gameOverText.classList.remove('hidden');
            restartBtn.classList.remove('hidden');
            startBtn.classList.add('hidden');
            overlay.classList.remove('hidden');
        }

        restartBtn.addEventListener('click', () => {
            location.reload(); 
        });
    </script>
</body>
</html>
